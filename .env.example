# .env.example - Šablona pro environment variables
#
# POKYNY:
# 1. Kopíruj tento soubor: cp .env.example .env
# 2. Vyplň svoje hodnoty
# 3. Načti do terminálu: source .env
# 4. Spusť aplikaci: python app.py
#
# ⚠️  POZOR: Nikdy nesdílej .env soubor (obsahuje API klíče!)
# NIKDY ho necommituj do git (je v .gitignore)
#

# ============ POVINNÉ ============

# OpenAI-compatible API klíč (z Kurim AI serveru)
OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxx"

# OpenAI-compatible API URL
OPENAI_BASE_URL="http://10.0.0.50:8000"

# ============ VOLITELNÉ ============

# Model pro AI (default: gemma3:27b)
OPENAI_MODEL="gemma3:27b"

# Port aplikace (default: 8081)
PORT="8081"

# Flask DEBUG mode (default: False - NIKDY True na produkci!)
FLASK_ENV="production"
FLASK_DEBUG="False"

# ============ PŘÍKLADY ============

# Příklad 1: Místní Ollama server
# OPENAI_BASE_URL="http://localhost:11434"
# OPENAI_API_KEY="dummy-local"
# OPENAI_MODEL="mistraal"

# Příklad 2: Hugging Face
# OPENAI_BASE_URL="https://api-inference.huggingface.co/v1"
# OPENAI_API_KEY="hf_xxxxxxxxxxxxx"
# OPENAI_MODEL="mistral"

# Příklad 3: LM Studio
# OPENAI_BASE_URL="http://localhost:8000"
# OPENAI_API_KEY="not-needed"

# ============ SPUŠTĚNÍ ============

# Bash
# source .env
# python app.py

# PowerShell (Windows)
# Get-Content .env | ForEach-Object { [Environment]::SetEnvironmentVariable($_.Split('=')[0], $_.Split('=')[1]) }
# python app.py

# Docker
# docker run -d --env-file .env -p 8081:8081 kushaeos:latest
