# .env.example - Šablona pro environment variables
#
# POKYNY:
# 1. Kopíruj tento soubor: cp .env.example .env
# 2. Vyplň svoje hodnoty
# 3. Spusť aplikaci přes Docker Compose: docker compose up
#
# ⚠️  POZOR: Nikdy nesdílej .env soubor (obsahuje API klíče!)
# NIKDY ho necommituj do git (je v .gitignore)
#

# ============ POVINNÉ ============

# Port na kterém běží aplikace
PORT=8081

# OpenAI-compatible API klíč (z Kurim AI serveru)
OPENAI_API_KEY=sk-REPLACE_ME

# OpenAI-compatible API URL
OPENAI_BASE_URL=https://kurim.ithope.eu/v1

# Model
OPENAI_MODEL=gemma3:27b

# ============ CHROMA DB (RAG) ============
# Pokud používáš docker compose, jsou tyto automaticky nastaveny
CHROMA_HOST=vectordb
CHROMA_PORT=8000

# ============ VOLITELNÉ ============
# Flask DEBUG mode (default: False - NIKDY True na produkci!)
FLASK_ENV="production"
FLASK_DEBUG="False"

# ============ SPUŠTĚNÍ ============
# Bash
# source .env
# python app.py

# PowerShell (Windows)
# Get-Content .env | ForEach-Object { [Environment]::SetEnvironmentVariable($_.Split('=')[0], $_.Split('=')[1]) }
# python app.py

# Docker
# docker run -d --env-file .env -p 8081:8081 kushaeos:latest
